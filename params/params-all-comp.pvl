(* Compromise parameters *)

letfun allow_CK_compromise = true.

letfun allow_RK_compromise = true.

letfun allow_DHs_compromise = true.

letfun allow_MK_compromise = true.

letfun allow_HK_compromise = true.

letfun allow_compromise =
allow_CK_compromise || allow_RK_compromise || allow_MK_compromise || allow_HK_compromise.

